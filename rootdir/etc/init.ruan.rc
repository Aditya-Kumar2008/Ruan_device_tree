# ruan-specific init

on boot
    chmod 0666 /dev/input/event2

# Display density override (POCO Pad 5G is a tablet)
on property:sys.boot_completed=1
    setprop ro.sf.lcd_density 280
    write /sys/devices/virtual/thermal/thermal_message/sconfig 20

# Enable PowerHAL hint processing
on property:vendor.powerhal.init=1
    setprop vendor.powerhal.init 1

on post-fs-data
    mkdir /data/vendor/misc 01771 system system

# NFC services - only enabled for NFC-capable SKUs (CN, GL, JP)
# Indian (IN) and most tablet SKUs do NOT have NFC hardware
service vendor.nfc_hal_service /vendor/bin/hw/android.hardware.nfc-service.nxp
    class early_hal
    user nfc
    group nfc drmrpc system
    override
    disabled

service secureelement-hal_1_2 /vendor/bin/hw/vendor.qti.secure_element@1.2-service
    class early_hal
    user system
    group system
    override
    disabled

service qti_esepowermanager_service_1_1 /vendor/bin/hw/vendor.qti.esepowermanager@1.1-service
    class early_hal
    user system
    group nfc system
    override
    disabled

# Enable NFC for Chinese SKU
on property:ro.boot.product.hardware.sku=CN
    enable vendor.nfc_hal_service
    enable secureelement-hal_1_2
    enable qti_esepowermanager_service_1_1

# Enable NFC for Global SKU
on property:ro.boot.product.hardware.sku=GL
    enable vendor.nfc_hal_service
    enable secureelement-hal_1_2
    enable qti_esepowermanager_service_1_1

# Enable NFC for Japan SKU
on property:ro.boot.product.hardware.sku=JP
    enable vendor.nfc_hal_service
    enable secureelement-hal_1_2
    enable qti_esepowermanager_service_1_1

# Audio HAL override
service vendor.audio-hal /vendor/bin/hw/android.hardware.audio.service
    override
    class hal
    user audioserver
    group audio camera drmrpc inet media mediadrm net_bt net_bt_admin net_bw_acct oem_2901 wakelock context_hub
    capabilities BLOCK_SUSPEND SYS_NICE
    rlimit rtprio 10 10
    ioprio rt 4
    task_profiles ProcessCapacityHigh HighPerformance
    onrestart restart audioserver
    socket audio_us_socket_0 seqpacket 0666 system system

# Sensors HAL override
service vendor.sensors-hal-multihal /vendor/bin/hw/android.hardware.sensors-service.xiaomi-multihal
    override
    class hal
    user system
    group system wakelock context_hub input uhid
    writepid /dev/cpuset/system-background/tasks
    socket audio_us_socket_1 seqpacket 0666 system system
    capabilities BLOCK_SUSPEND
    rlimit rtprio 10 10